    <PackageReference Include="Microsoft.AspNetCore.Authentication.Google" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.MicrosoftAccount" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" />
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" />
    <PackageReference Include="AspNet.Security.OAuth.Amazon" />
    <PackageReference Include="AspNet.Security.OAuth.Apple" />
    <PackageReference Include="AspNet.Security.OAuth.Discord" />
    <PackageReference Include="AspNet.Security.OAuth.GitHub" />
    <PackageReference Include="AspNet.Security.OAuth.GitLab" />
    <PackageReference Include="AspNet.Security.OAuth.LinkedIn" />
    <PackageReference Include="AspNet.Security.OAuth.Notion" />
    <PackageReference Include="AspNet.Security.OAuth.Reddit" />
    <PackageReference Include="AspNet.Security.OAuth.Slack" />
    <PackageReference Include="AspNet.Security.OAuth.Spotify" />
    <PackageReference Include="AspNet.Security.OAuth.Twitch" />
    <PackageReference Include="AspNet.Security.OAuth.Twitter" />
    <PackageReference Include="AspNet.Security.OAuth.Vkontakte" />
    <PackageReference Include="AspNet.Security.OAuth.Yandex" />
    <PackageReference Include="Telegram.Bot" />
    <PackageReference Include="Fido2.AspNet" />
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" />
    <PackageReference Include="Otp.NET" />
    <PackageReference Include="Google.Apis.Auth" />
  </ItemGroup>

  <ItemGroup Label="Comms — email">
    <PackageReference Include="MailKit" />
    <PackageReference Include="SendGrid" />
    <PackageReference Include="AWSSDK.SimpleEmailV2" />
  </ItemGroup>

  <!-- Hangfire is LGPL-3.0 — the one exception to the permissive-only rule, blessed by targets.md §6 (P4).
       Revisit if/when the SDK distills to a non-beta lib. -->
  <ItemGroup Label="Jobs — Hangfire">
    <PackageReference Include="Hangfire.Core" />
    <PackageReference Include="Hangfire.AspNetCore" />
    <PackageReference Include="Hangfire.InMemory" />
    <PackageReference Include="Hangfire.PostgreSql" />
