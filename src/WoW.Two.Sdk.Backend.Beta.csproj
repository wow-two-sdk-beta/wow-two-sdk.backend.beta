<Project Sdk="Microsoft.NET.Sdk">

  <!--
    MONO-LIB (beta-forever).

    One class library compiling every shipping concern under src/ (foundation, observability,
    web, mediator, identity, data, …) — divided by FOLDERS, not projects. The folder tree is
    unchanged; only the per-concern .csproj boundaries were removed. Namespaces match their folder
    path 1:1, including nested provider leaves (e.g. WoW.Two.Sdk.Backend.Beta.Comms.Email.MailKit
    lives in src/Comms/Email/MailKit/, …Jobs.Hangfire.Postgres in src/Jobs/Hangfire/Postgres/).

    Why: kill the create-csproj / wire-ProjectReference / build-graph / version-per-package cycle.
    Push one package, iterate fast. We split back into granular packages when the surface is
    mature and saturated. Cost accepted: this package's transitive closure is large (every DB
    driver, OpenTelemetry, Serilog, etc.).

    Test helpers (P0) ship as a SEPARATE mono-lib (Testing/WoW.Two.Sdk.Backend.Beta.Testing.csproj)
    so xUnit / Testcontainers never leak into a production reference. Excluded from this compile below.
  -->

  <PropertyGroup>
    <!-- Published ID uses the OWNED WoW2.* reserved prefix. Assembly + namespaces remain WoW.Two.* (full rename later). -->
    <PackageId>WoW2.Sdk.Backend.Beta</PackageId>
    <Description>WoW Two backend SDK (beta-forever mono-lib) — foundation, observability, web, mediator, identity, and data concerns in one package, divided by folders.</Description>
    <PackageTags>wow-two; backend; beta; sdk; aspnet; mono</PackageTags>

    <!-- Exclude the testing mono-lib tree, the web-free Data/Abstractions project tree, the web-free
         migrator CLI tree (its own Exe project), and any stray build artifacts from this compile.
         Each is its own project (referenced/standalone); globbing them here too would double-compile their types.
         Paths MUST match the on-disk casing (now all PascalCase: Testing, Data/Migrations/cli) — MSBuild globs
         are case-sensitive on Linux CI, so a lowercase 'testing/**' or 'data/migrations/cli/**' silently fails to
         exclude there and drags those projects' types into the mono-lib compile (CS0234/CS0246). macOS is
         case-insensitive and hides this — keep PascalCase. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);Testing/**;Testing.Data/**;Testing.Integrations/**;Mediator.Tests/**;Migrations.Tests/**;Foundation.Tests/**;Web.Tests/**;Messaging.Tests/**;Identity.Tests/**;Data/Abstractions/**;Data/Migrations/cli/**;**/obj/**;**/bin/**</DefaultItemExcludes>
  </PropertyGroup>

  <!-- web/*, identity/*, mediator/authorization compile against the ASP.NET Core shared framework. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- The web-free data-contracts seam (IDbConnectionFactory, entity/repository interfaces). Referencing it
       (not globbing it) keeps a single type identity so every consumer of IDbConnectionFactory still resolves. -->
  <ItemGroup>
    <ProjectReference Include="Data/Abstractions/WoW.Two.Sdk.Backend.Beta.Data.Abstractions.csproj" />
  </ItemGroup>

  <!--
    The former "excluded pending ASP.NET reference-conflict fix" block is gone — all five CS1061s were
    missing using directives, never a reference conflict: AddApple / AddGitHub / AddMicrosoftAccount live in
    `Microsoft.Extensions.DependencyInjection`, AddRateLimiter / AddResponseCompression in
    `Microsoft.AspNetCore.Builder`. Fixed in the five files; nothing is excluded anymore.
  -->

  <ItemGroup Label="Foundation / language">
    <PackageReference Include="Ardalis.GuardClauses" />
    <PackageReference Include="Ardalis.Result" />
    <PackageReference Include="ErrorOr" />
    <PackageReference Include="OneOf" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="Humanizer.Core" />
    <PackageReference Include="NodaTime" />
    <PackageReference Include="NodaTime.Serialization.SystemTextJson" />
    <PackageReference Include="Cronos" />
    <PackageReference Include="TimeZoneConverter" />
    <PackageReference Include="StronglyTypedId" />
    <PackageReference Include="Vogen" />
  </ItemGroup>

  <!--
    Microsoft.Extensions.* (DI, Options, Logging, Hosting, Configuration, Caching, HealthChecks) are
    provided by the Microsoft.AspNetCore.App shared framework referenced above. Referencing them as
    NuGet packages too splits type identity (e.g. two IServiceCollection), which breaks shared-framework
    extension-method resolution (AddResponseCompression, AddRateLimiter, …). So they are intentionally NOT
    listed here — the FrameworkReference supplies them.
  -->

  <ItemGroup Label="Web / ASP.NET Core">
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Asp.Versioning.Http" />
    <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer" />
    <PackageReference Include="Hellang.Middleware.ProblemDetails" />
    <PackageReference Include="NetEscapades.AspNetCore.SecurityHeaders" />
  </ItemGroup>

  <!-- Realtime — SignalR/SSE/WebSockets conventions (src/Realtime/). SignalR + WebSockets + .NET 10 SSE
       come from the Microsoft.AspNetCore.App shared framework; only the Redis backplane is an add-on package. -->
  <ItemGroup Label="Realtime — SignalR Redis backplane">
    <PackageReference Include="Microsoft.AspNetCore.SignalR.StackExchangeRedis" />
  </ItemGroup>

  <ItemGroup Label="Http / outbound — Refit + Polly v8 resilience + header propagation">
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
    <PackageReference Include="Microsoft.AspNetCore.HeaderPropagation" />
    <PackageReference Include="Refit" />
    <PackageReference Include="Refit.HttpClientFactory" />
  </ItemGroup>

  <ItemGroup Label="Identity / auth">
